<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Удаляем дубликат «Главная», если модуль уже был установлен ранее -->
  <delete model="website.menu" id="menu_conditioners_home"/>

  <!-- Используем стандартный пункт Odoo для главной страницы -->
  <record id="website.menu_home" model="website.menu">
    <field name="name">Главная</field>
  </record>

  <!-- Удаляем стандартный пункт Contact us из меню -->
  <delete model="website.menu" id="menu_contactus"/>

  <!-- Placeholder обязателен для t-call в шапке -->
  <record id="website.placeholder_header_call_to_action" model="ir.ui.view">
    <field name="active" eval="True"/>
  </record>
</odoo>
