<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_conditioners_review_list" model="ir.ui.view">
        <field name="name">conditioners.review.list</field>
        <field name="model">conditioners.review</field>
        <field name="arch" type="xml">
            <list string="Отзывы" default_order="sequence,id desc">
                <field name="sequence" widget="handle"/>
                <field name="image" widget="image" options="{'size': [64, 64]}"/>
                <field name="name"/>
                <field name="city" optional="show"/>
                <field name="is_published" widget="boolean_toggle"/>
                <field name="website_id" groups="website.group_multi_website" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_conditioners_review_form" model="ir.ui.view">
        <field name="name">conditioners.review.form</field>
        <field name="model">conditioners.review</field>
        <field name="arch" type="xml">
            <form string="Отзыв">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Иван М."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="city"/>
                            <field name="sequence"/>
                            <field name="is_published"/>
                        </group>
                        <group>
                            <field name="website_id" groups="website.group_multi_website"/>
                        </group>
                    </group>
                    <group>
                        <field name="review_text" placeholder="Текст отзыва (необязательно, если загружаете скриншот)"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_conditioners_review_search" model="ir.ui.view">
        <field name="name">conditioners.review.search</field>
        <field name="model">conditioners.review</field>
        <field name="arch" type="xml">
            <search string="Отзывы">
                <field name="name"/>
                <field name="city"/>
                <filter string="На сайте" name="published" domain="[('is_published', '=', True)]"/>
                <filter string="Скрыты" name="hidden" domain="[('is_published', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_conditioners_review" model="ir.actions.act_window">
        <field name="name">Отзывы</field>
        <field name="res_model">conditioners.review</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_published': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Добавьте отзыв клиента
            </p>
            <p>
                Загрузите скриншот отзыва или фото, при необходимости укажите имя и текст.
                Опубликованные отзывы автоматически появятся на странице «Отзывы» и на главной.
            </p>
        </field>
    </record>

    <menuitem
        id="menu_conditioners_review"
        name="Отзывы"
        parent="website.menu_content"
        action="action_conditioners_review"
        sequence="25"
        groups="website.group_website_designer"/>
</odoo>
