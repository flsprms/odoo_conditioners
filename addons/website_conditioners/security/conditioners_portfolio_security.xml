<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="conditioners_portfolio_public_rule" model="ir.rule">
        <field name="name">Published portfolio only (public)</field>
        <field name="model_id" ref="model_conditioners_portfolio"/>
        <field name="domain_force">[('is_published', '=', True)]</field>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
