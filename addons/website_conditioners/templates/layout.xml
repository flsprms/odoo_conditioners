<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="s_conditioners_topbar" name="Conditioners top bar">
        <div class="o_conditioners_topbar bg-dark text-white py-1">
            <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2 small">
                <span>Москва · ежедневно 9:00–21:00</span>
                <div class="d-flex flex-wrap gap-3">
                    <a href="tel:+79990000000" class="text-white text-decoration-none">
                        <i class="fa fa-phone me-1"/> +7 (999) 000-00-00
                    </a>
                    <a href="https://wa.me/79990000000" class="text-white text-decoration-none" target="_blank" rel="noopener noreferrer">
                        <i class="fa fa-whatsapp me-1"/> WhatsApp
                    </a>
                </div>
            </div>
        </div>
    </template>

    <template id="layout_topbar" inherit_id="website.layout" name="Conditioners layout topbar">
        <xpath expr="//header" position="before">
            <t t-call="website_conditioners.s_conditioners_topbar"/>
        </xpath>
    </template>

    <template id="layout_whatsapp_float" inherit_id="website.layout" name="Conditioners WhatsApp float">
        <xpath expr="//div[@id='wrapwrap']" position="inside">
            <a href="https://wa.me/79990000000"
               class="o_conditioners_whatsapp_float d-none d-md-flex"
               target="_blank"
               rel="noopener noreferrer"
               aria-label="Написать в WhatsApp"
               title="Написать в WhatsApp">
                <i class="fa fa-whatsapp"/>
            </a>
        </xpath>
    </template>
</odoo>
