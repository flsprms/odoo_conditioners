<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_material_kit_tree" model="ir.ui.view">
        <field name="name">crm.material.kit.list</field>
        <field name="model">crm.material.kit</field>
        <field name="arch" type="xml">
            <list string="Material Kits">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="is_default" />
                <field name="active" />
            </list>
        </field>
    </record>

    <record id="view_crm_material_kit_form" model="ir.ui.view">
        <field name="name">crm.material.kit.form</field>
        <field name="model">crm.material.kit</field>
        <field name="arch" type="xml">
            <form string="Material Kit">
                <sheet>
                    <div class="oe_button_box" name="button_box" />
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active" />
                    <group>
                        <group>
                            <field name="name" />
                            <field name="company_id" groups="base.group_multi_company" />
                            <field name="is_default" />
                        </group>
                        <group>
                            <field name="sequence" />
                            <field name="active" />
                        </group>
                    </group>
                    <group string="Default for leads">
                        <group>
                            <field name="default_material_formula_x" />
                            <field
                                name="default_material_base_product_id"
                                options="{'no_create': True}"
                            />
                        </group>
                    </group>
                    <notebook>
                        <page string="Components" name="lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle" />
                                    <field name="product_id" />
                                    <field name="name" optional="show" />
                                    <field name="product_uom_qty" />
                                    <field name="qty_formula" optional="show" />
                                    <field
                                        name="formula_base_product_id"
                                        optional="hide"
                                        options="{'no_create': True}"
                                    />
                                    <field
                                        name="product_uom_id"
                                        groups="uom.group_uom"
                                    />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crm_material_kit" model="ir.actions.act_window">
        <field name="name">Material Kits</field>
        <field name="res_model">crm.material.kit</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define reusable material lists for opportunities (e.g. standard mounting set).
            </p>
        </field>
    </record>

    <menuitem
        id="menu_crm_material_kit"
        name="Material Kits"
        parent="crm.crm_menu_config"
        action="action_crm_material_kit"
        sequence="60"
    />
</odoo>
